# -----------------------
# POLY-APEX Environment Configuration
# -----------------------

# -----------------------
# API & Access Keys
# -----------------------
# Your Polymarket API Key (Needed for CLOB Executor and any private endpoints)
POLYMARKET_API_KEY="00000000-0000-0000-0000-000000000000"

# Your Polymarket Secret Key
POLYMARKET_API_SECRET="YOUR_POLYMARKET_SECRET"

# Your Polymarket Passphrase
POLYMARKET_API_PASSPHRASE="YOUR_POLYMARKET_PASSPHRASE"

# Your Polygon Wallet Private Key (Required for EIP-712 signing & order submission)
# Starts with '0x' or without. KEEP THIS SAFE.
WALLET_PRIVATE_KEY="YOUR_PRIVATE_KEY_HERE"

# -----------------------
# External Services
# -----------------------
# Polygon RPC Node URL (Alchemy, Infura, etc.)
# Overrides config.toml [rpc] polygon_rpc
POLYGON_RPC="https://polygon-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY"

# Telegram Bot Token (from BotFather)
TELEGRAM_BOT_TOKEN="123456789:ABCDEF_GHIJKLMNOPQRSTUVWXYZ"

# -----------------------
# Storage & Database
# -----------------------
# TimescaleDB Connection String (PostgreSQL)
# Format: postgres://user:password@host:port/dbname
DATABASE_URL="postgres://postgres:password@localhost:5432/poly_apex"
