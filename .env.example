# ─── POLY-APEX Copy Trader ─── Environment Variables ───

# ── Secrets ──
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=
WALLET_PRIVATE_KEY=
TELEGRAM_BOT_TOKEN=
POLYGON_RPC=https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY
DATABASE_URL=postgres://postgres:password@localhost:5432/poly_apex

# ── Wallets ──
WALLET_TARGETS=0xWALLET1,0xWALLET2
AUTO_DISCOVER=false
MAX_WATCHED_WALLETS=20

# ── Copy Trading ──
LIVE_TRADING=false
PAPER_BALANCE_USDC=1000.0
COPY_RATIO=0.5
SIZING_MODE=kelly
FIXED_USDC=10.0
MAX_SINGLE_TRADE_USDC=100.0
MIN_MARKET_LIQUIDITY_USDC=500.0
MIN_COPY_SIZE_USDC=2.0
COOLDOWN_PER_MARKET_SECS=60
DEDUP_WINDOW_SECS=30

# ── Risk ──
DAILY_MAX_LOSS_USDC=300.0
MAX_OPEN_POSITIONS=10
MAX_SLIPPAGE_PCT=2.5
CONSECUTIVE_LOSS_HALT=3
HALT_DURATION_MINS=15

# ── RPC ──
BACKUP_RPC=https://rpc-mainnet.matic.network
CONFIRMATION_TIMEOUT_SECS=60

# ── Telegram ──
TELEGRAM_ALLOWED_IDS=YOUR_TELEGRAM_USER_ID
